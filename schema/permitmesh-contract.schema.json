{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/JalenBuildsHub/PermitMesh/v0.2.0/schema/permitmesh-contract.schema.json",
  "title": "PermitMesh Capability Contract 0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "issuer",
    "subject",
    "scope",
    "capabilities",
    "validity",
    "limits",
    "approval_gates",
    "operation_constraints",
    "lifecycle",
    "validation"
  ],
  "properties": {
    "contract_version": {"const": "0.2"},
    "issuer": {"$ref": "#/$defs/principal"},
    "subject": {"$ref": "#/$defs/principal"},
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repositories", "channels"],
      "properties": {
        "repositories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "refs", "allow_paths", "deny_paths"],
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "refs": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {"type": "string", "minLength": 1}
              },
              "allow_paths": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {"type": "string", "minLength": 1}
              },
              "deny_paths": {
                "type": "array",
                "uniqueItems": true,
                "items": {"type": "string", "minLength": 1}
              }
            }
          }
        },
        "channels": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["read", "edit", "shell", "test", "commit", "review", "deploy", "publish", "spend"]
      }
    },
    "validity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["not_before", "expires_at"],
      "properties": {
        "not_before": {"type": "string", "format": "date-time"},
        "expires_at": {"type": "string", "format": "date-time"}
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_files_changed", "max_commands", "max_cost_usd"],
      "properties": {
        "max_files_changed": {"type": "integer", "minimum": 0},
        "max_commands": {"type": "integer", "minimum": 0},
        "max_cost_usd": {"type": "number", "minimum": 0}
      }
    },
    "approval_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["actions", "min_approvals", "approvers"],
        "properties": {
          "actions": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "enum": ["read", "edit", "shell", "test", "commit", "review", "deploy", "publish", "spend"]
            }
          },
          "min_approvals": {"type": "integer", "minimum": 1},
          "approvers": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "operation_constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action", "operation_digest", "nonce"],
        "properties": {
          "action": {
            "enum": ["shell", "test", "commit", "deploy", "publish", "spend"]
          },
          "operation_digest": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "nonce": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]{16,128}$"
          }
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_id", "fencing_generation"],
      "properties": {
        "claim_id": {"type": "string", "minLength": 1},
        "fencing_generation": {"type": "integer", "minimum": 1}
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_commands", "required_artifacts"],
      "properties": {
        "required_commands": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "required_artifacts": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "signature": {
      "type": "object",
      "description": "Optional transport-independent signature metadata. Verification is adapter-specific.",
      "additionalProperties": false,
      "required": ["algorithm", "public_key", "value"],
      "properties": {
        "algorithm": {"type": "string", "minLength": 1},
        "public_key": {"type": "string", "minLength": 1},
        "value": {"type": "string", "minLength": 1}
      }
    }
  },
  "$defs": {
    "principal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "display_name": {"type": "string"}
      }
    }
  }
}
