{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/JalenBuildsHub/PermitMesh/v0.2.0/schema/permitmesh-completion-report.schema.json",
  "title": "PermitMesh Completion Report 0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "subject_id",
    "claim_id",
    "fencing_generation",
    "commands_passed",
    "artifacts_present"
  ],
  "properties": {
    "subject_id": {"type": "string", "minLength": 1},
    "claim_id": {"type": "string", "minLength": 1},
    "fencing_generation": {"type": "integer", "minimum": 1},
    "commands_passed": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "artifacts_present": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
