{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://permitmesh.dev/schema/permitmesh-conformance-receipt-0.1.json",
  "title": "PermitMesh Conformance Receipt 0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_version",
    "implementation",
    "suite",
    "generated_at",
    "enforcement_boundary",
    "summary",
    "cases"
  ],
  "properties": {
    "receipt_version": {"const": "0.1"},
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1}
      }
    },
    "suite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "digest"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"const": "0.1"},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "generated_at": {"type": "string", "format": "date-time"},
    "enforcement_boundary": {"type": "string", "minLength": 1},
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "passed", "failed"],
      "properties": {
        "total": {"type": "integer", "minimum": 1},
        "passed": {"type": "integer", "minimum": 0},
        "failed": {"type": "integer", "minimum": 0}
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "expected_outcome",
          "observed_outcome",
          "passed"
        ],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "expected_outcome": {"enum": ["allow", "deny", "malformed"]},
          "observed_outcome": {"enum": ["allow", "deny", "malformed"]},
          "passed": {"type": "boolean"},
          "decision": {"type": "object"},
          "error": {"type": "string"}
        }
      }
    }
  }
}
