{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/JalenBuildsHub/PermitMesh/v0.2.0/schema/permitmesh-request.schema.json",
  "title": "PermitMesh Action Request 0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "subject_id",
    "action",
    "repository",
    "ref",
    "files_changed",
    "commands_used",
    "cost_usd",
    "claim_id",
    "fencing_generation",
    "approvals"
  ],
  "properties": {
    "subject_id": {"type": "string", "minLength": 1},
    "action": {
      "enum": ["read", "edit", "shell", "test", "commit", "review", "deploy", "publish", "spend"]
    },
    "channel": {"type": "string", "minLength": 1},
    "repository": {"type": "string", "minLength": 1},
    "ref": {"type": "string", "minLength": 1},
    "path": {"type": "string", "minLength": 1},
    "files_changed": {"type": "integer", "minimum": 0},
    "commands_used": {"type": "integer", "minimum": 0},
    "cost_usd": {"type": "number", "minimum": 0},
    "claim_id": {"type": "string", "minLength": 1},
    "fencing_generation": {"type": "integer", "minimum": 1},
    "approvals": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "arguments"],
      "properties": {
        "tool": {"type": "string", "minLength": 1},
        "arguments": {"type": "object"}
      }
    },
    "operation_nonce": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]{16,128}$"
    },
    "at": {"type": "string", "format": "date-time"}
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "action": {
            "enum": ["shell", "test", "commit", "deploy", "publish", "spend"]
          }
        },
        "required": ["action"]
      },
      "then": {
        "required": ["operation", "operation_nonce"]
      }
    }
  ]
}
